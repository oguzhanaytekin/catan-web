{
  "name": "catan-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run server\"",
    "server": "tsx watch server/index.ts",
